{
  "name": "cruise-ship-log",
  "version": "0.1.0",
  "private": true,
  "description": "A web-based cruise travel journal",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && cp -r dist/* .vercel/output/static/ && vercel deploy --prebuilt --prod --force"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "clsx": "^2.1.1",
    "dexie": "^4.4.3",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.14.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0",
    "react-simple-maps": "4.0.0-beta.6",
    "tailwind-merge": "^3.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "4.5.1",
    "@vitest/ui": "^4.1.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
